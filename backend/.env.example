# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=webside_db
DB_PORT=3306

# ============================================
# JWT CONFIGURATION
# ============================================
# IMPORTANT: Change this to a strong, random secret in production!
# You can generate one using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-at-least-32-characters
JWT_EXPIRES_IN=24h

# ============================================
# CORS CONFIGURATION
# ============================================
# For development, use your frontend URL
# For production, use your production domain
CORS_ORIGIN=http://localhost:5173

# ============================================
# RATE LIMITING (Optional but recommended)
# ============================================
# Time window in milliseconds (15 minutes = 900000ms)
RATE_LIMIT_WINDOW_MS=900000
# Maximum number of requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# EMAIL CONFIGURATION (Optional - for sending emails)
# ============================================
# SMTP Configuration for sending emails (contracts, invoices, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM_NAME=Webside System
SMTP_FROM_EMAIL=noreply@yourcompany.com

# ============================================
# WHATSAPP INTEGRATION (Optional - for sending documents)
# ============================================
# WhatsApp Business API Configuration
WHATSAPP_API_KEY=your-whatsapp-api-key-here
WHATSAPP_PHONE=+5511999999999
WHATSAPP_API_URL=https://api.whatsapp.com/send

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
# Maximum file size in bytes (10MB = 10485760)
MAX_FILE_SIZE=10485760
# Allowed file types
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ============================================
# LOGGING CONFIGURATION
# ============================================
# Log level: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info
# Log to file (true/false)
LOG_TO_FILE=true
# Log directory
LOG_DIR=logs

# ============================================
# SESSION CONFIGURATION
# ============================================
SESSION_SECRET=your-session-secret-change-this-in-production
SESSION_MAX_AGE=86400000

# ============================================
# SECURITY HEADERS
# ============================================
# Enable security headers (helmet)
ENABLE_HELMET=true
# Enable HTTPS redirect in production
FORCE_HTTPS=false

# ============================================
# BACKUP CONFIGURATION (Optional)
# ============================================
# Automatic database backup
ENABLE_AUTO_BACKUP=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30

# ============================================
# REDIS CONFIGURATION (Optional - for caching)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
ENABLE_REDIS_CACHE=false

# ============================================
# MONITORING & ANALYTICS (Optional)
# ============================================
# Sentry for error tracking
SENTRY_DSN=
# Google Analytics
GA_TRACKING_ID=

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_WHATSAPP_NOTIFICATIONS=false
ENABLE_PDF_GENERATION=true
ENABLE_REPORTS=true
ENABLE_AUDIT_LOG=true

# ============================================
# DEVELOPMENT ONLY
# ============================================
# Enable test users (allows login without database)
ENABLE_TEST_USERS=true
# Enable detailed error messages
ENABLE_DETAILED_ERRORS=true
# Enable SQL query logging
LOG_SQL_QUERIES=false
